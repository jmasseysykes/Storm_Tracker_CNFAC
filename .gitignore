# Create or append to .gitignore
cat << 'EOF' >> .gitignore
# Jupyter / notebooks
*.ipynb
*.ipynb_checkpoints/

# Data / generated
*.csv
*.xlsx
*.png
!StormTracker_Screenshot.png
*.log
temp_plot.png

# Old / test scripts
*test.py
*v1.*.py
untitled.py

# R / misc
.Rhistory
EOF# Python / temp
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage

# Jupyter / notebooks
*.ipynb_checkpoints/
*.ipynb

# Data / generated files
# Ignore generated/output CSVs (keep essential ones like station lists)
*.csv
!SNOTEL_station_list.csv
output/*.csv
data/*.csv
*.xlsx
*.png
*.log
data/
output/
temp/
plots/

# Old/test scripts
*test.py
*v1.*.py
untitled.py

# Editor/OS
.DS_Store
Thumbs.db
.idea/
.vscode/
